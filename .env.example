# Copy to .env and adjust if needed. NO SECRETS are required — both APIs are
# public and keyless. Config is externalised here purely for good hygiene.

# How many forecast days to pull (today + following days).
FORECAST_DAYS=3

# How many days back to request observed actuals from the ERA5 archive.
# (ERA5 lags ~5 days, so the most recent days in the window may be null.)
ARCHIVE_LOOKBACK_DAYS=7

# Enrich each Polymarket bucket with a live CLOB order-book midpoint quote.
CLOB_ENRICH=true

# Only snapshot markets that are still open (recommended for live ingestion).
ONLY_OPEN_MARKETS=true

# Per-request HTTP timeout in seconds.
HTTP_TIMEOUT_SECONDS=30

# --- Target cities -----------------------------------------------------------
# Cities are defined in config.py (name + lat/lon + timezone) because each entry
# is a small structured record, not a flat string. Edit CITIES there to add more
# (Polymarket already has live daily-temperature markets for Paris, London,
# Madrid, Tokyo, Seoul, Singapore, ... so expanding is trivial).
